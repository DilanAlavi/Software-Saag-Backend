generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TipoUbicacion {
  CENTRAL
  SUCURSAL
  DEPOSITO
}

enum TipoProducto {
  CARPINTERIA
  FERRETERIA
  PLOMERIA
  ELECTRICO
}

enum AccionProducto {
  CREACION
  ELIMINACION
}

enum ModalidadVentaPaquete {
  PIEZA
  PAQUETE
  AMBOS
}

enum EstadoVenta {
  PENDIENTE
  PAGADO
  CANCELADO
}

enum MotivoCancelacion {
  NO_RECOGIO
  CLIENTE_CANCELO
}

model Producto {
  id                  Int          @id @default(autoincrement())
  nombre              String
  nombresAlternativos String[]
  marca               String?
  tipoProducto        TipoProducto
  codigo              String?      @unique
  estado              Boolean      @default(true)
  fechaRegistro       DateTime     @default(now())

  unidadesPorPaquete  Int?
  unidadesPorCaja     Int?
  ventaSoloPorPaquete Boolean      @default(false)
  // Etiqueta para mostrar en pantalla (ej. "par", "juego"). Null = se muestra "pcs".
  unidadVenta         String?

  historial HistorialProducto[]
  precio    Precio?
  stock     Stock[]
  gruposPrecioEspecial GrupoPrecioEspecialProducto[]
  detallesVenta DetalleVenta[]
}

model Stock {
  id                        Int      @id @default(autoincrement())
  productoId                Int
  producto                  Producto @relation(fields: [productoId], references: [id])
  sucursalId                Int
  sucursal                  Sucursal @relation(fields: [sucursalId], references: [id])
  area                      String?
  cantidad                  Int?
  confirmado                Boolean  @default(false)
  cantidadVendidaAcumulada  Int      @default(0)
  fechaActualizacion        DateTime @updatedAt

  @@unique([productoId, sucursalId])
}

model Venta {
  id                 Int                @id @default(autoincrement())
  clienteId          Int
  cliente            Cliente            @relation(fields: [clienteId], references: [id])
  usuarioId          Int
  usuario            Usuario            @relation(fields: [usuarioId], references: [id])
  sucursalId         Int
  sucursal           Sucursal           @relation(fields: [sucursalId], references: [id])
  estado             EstadoVenta        @default(PENDIENTE)
  motivoCancelacion  MotivoCancelacion?
  fecha              DateTime           @default(now())
  total              Decimal
  efectivoRecibido   Decimal?
  vuelto             Decimal?
  fechaPago          DateTime?
  reporte            String?
  fechaReporte       DateTime?

  detalles DetalleVenta[]
}

model DetalleVenta {
  id              Int     @id @default(autoincrement())
  ventaId         Int
  venta           Venta   @relation(fields: [ventaId], references: [id])
  productoId      Int
  producto        Producto @relation(fields: [productoId], references: [id])
  nombreProducto  String
  cantidad        Int
  precioUnitario  Decimal
  total           Decimal
  entregado       Boolean @default(false)
}

model Precio {
  id          Int      @id @default(autoincrement())
  productoId  Int      @unique
  producto    Producto @relation(fields: [productoId], references: [id])

  precioCosto  Decimal

  menor1       Decimal
  menor2       Decimal
  mayor1       Decimal
  mayor2       Decimal
  plomeria     Decimal
  carpinteria  Decimal
  electricista Decimal

  precioCaja        Decimal?
  precioPiezaSuelta Decimal?

  cantidadMinimaDescuentoMenor1 Int?
  precioDescuentoMenor1         Decimal?

  fechaActualizacion DateTime @updatedAt
}

model GrupoPrecioEspecial {
  id                Int        @id @default(autoincrement())
  nombre            String     @unique
  categoriaAsignada RolCliente
  estado            Boolean    @default(true)
  fechaRegistro      DateTime  @default(now())

  productos GrupoPrecioEspecialProducto[]
  clientes  ClienteGrupoPrecioEspecial[]
}

model GrupoPrecioEspecialProducto {
  id         Int                 @id @default(autoincrement())
  grupoId    Int
  grupo      GrupoPrecioEspecial @relation(fields: [grupoId], references: [id])
  productoId Int
  producto   Producto            @relation(fields: [productoId], references: [id])

  @@unique([grupoId, productoId])
}

model ClienteGrupoPrecioEspecial {
  id        Int                 @id @default(autoincrement())
  clienteId Int
  cliente   Cliente             @relation(fields: [clienteId], references: [id])
  grupoId   Int
  grupo     GrupoPrecioEspecial @relation(fields: [grupoId], references: [id])

  @@unique([clienteId, grupoId])
}

model HistorialProducto {
  id             Int            @id @default(autoincrement())
  productoId     Int
  producto       Producto       @relation(fields: [productoId], references: [id])
  accion         AccionProducto
  fecha          DateTime       @default(now())
  realizadoPorId Int
  realizadoPor   Usuario        @relation(fields: [realizadoPorId], references: [id])
}

enum RolUsuario {
  ADMIN
  ADMIN_SUCURSAL
  VENDEDOR
}

enum RolCliente {
  MAYOR_1
  MAYOR_2
  STANDARD_1
  STANDARD_2
  CARPINTERIA
  PLOMERIA
  ELECTRICISTA
}

model Sucursal {
  id                     Int                    @id @default(autoincrement())
  nombre                 String
  tipo                   TipoUbicacion
  departamento           String?
  ciudad                 String?
  zona                   String?
  referencia             String?
  estado                 Boolean                @default(true)
  createdAt              DateTime               @default(now())
  modalidadVentaPaquete  ModalidadVentaPaquete?
  usuarios               Usuario[]
  stock                  Stock[]
  ventas                 Venta[]
}

model Usuario {
  id              Int        @id @default(autoincrement())
  nombre          String
  apellidoPaterno String
  apellidoMaterno String?
  ci              String?    @unique
  celular         String
  genero          String?
  username        String     @unique
  password        String
  rol             RolUsuario
  estado          Boolean    @default(true)
  fechaRegistro   DateTime   @default(now())
  sucursalId      Int?
  sucursal        Sucursal?  @relation(fields: [sucursalId], references: [id])

  historialComoSujeto HistorialEstadoUsuario[] @relation("HistorialUsuarioSujeto")
  historialComoActor  HistorialEstadoUsuario[] @relation("HistorialUsuarioActor")
  historialClientesRealizado HistorialEstadoCliente[]
  historialProductosRealizado HistorialProducto[]
  ventas Venta[]
}

model Cliente {
  id              Int        @id @default(autoincrement())
  nombre          String
  apellidoPaterno String
  apellidoMaterno String?
  ci              String?    @unique
  celular         String
  genero          String?
  rol             RolCliente
  estado          Boolean    @default(true)
  fechaRegistro   DateTime   @default(now())

  historial HistorialEstadoCliente[]
  gruposPrecioEspecial ClienteGrupoPrecioEspecial[]
  ventas Venta[]
}

model HistorialEstadoUsuario {
  id             Int      @id @default(autoincrement())
  usuarioId      Int
  usuario        Usuario  @relation("HistorialUsuarioSujeto", fields: [usuarioId], references: [id])
  estadoAnterior Boolean
  estadoNuevo    Boolean
  fecha          DateTime @default(now())
  realizadoPorId Int
  realizadoPor   Usuario  @relation("HistorialUsuarioActor", fields: [realizadoPorId], references: [id])
}

model HistorialEstadoCliente {
  id             Int      @id @default(autoincrement())
  clienteId      Int
  cliente        Cliente  @relation(fields: [clienteId], references: [id])
  estadoAnterior Boolean
  estadoNuevo    Boolean
  fecha          DateTime @default(now())
  realizadoPorId Int
  realizadoPor   Usuario  @relation(fields: [realizadoPorId], references: [id])
}
