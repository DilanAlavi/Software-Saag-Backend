generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Producto {
  id        Int      @id @default(autoincrement())
  nombre    String
  precio    Decimal
  stock     Int
  createdAt DateTime @default(now())
}
